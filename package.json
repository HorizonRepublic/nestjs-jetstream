{
  "name": "@horizon-republic/nestjs-jetstream",
  "version": "2.13.0",
  "description": "A NestJS transport for NATS with JetStream events, broadcast fan-out, and Core/JetStream RPC.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HorizonRepublic/nestjs-jetstream.git"
  },
  "homepage": "https://nestjs-jetstream.horizon-republic.dev/",
  "bugs": {
    "url": "https://github.com/HorizonRepublic/nestjs-jetstream/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "nestjs",
    "jetstream",
    "nats",
    "transport",
    "microservices",
    "rpc",
    "events"
  ],
  "author": {
    "name": "Horizon Republic",
    "url": "https://github.com/HorizonRepublic"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "!dist/*.map",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">= 20.0.0"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "start:example": "pnpm build && tsx --tsconfig examples/tsconfig.json examples/01-basic/main.ts",
    "dev:example": "tsx --tsconfig examples/tsconfig.json examples/01-basic/main.ts",
    "prepublishOnly": "pnpm build",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "docs:dev": "pnpm --filter ./website start",
    "docs:build": "pnpm --filter ./website build",
    "docs:serve": "pnpm --filter ./website serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "bench": "node --expose-gc --import tsx benchmarks/harness/cli.ts",
    "bench:codec": "pnpm bench codec",
    "bench:route": "pnpm bench route-pipeline",
    "bench:all": "pnpm bench all",
    "bench:quick": "pnpm bench all --quick",
    "bench:diff": "node --import tsx benchmarks/harness/diff-cli.ts"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.2.0 || ^11.0.0",
    "@nestjs/core": "^10.2.0 || ^11.0.0",
    "@nestjs/microservices": "^10.2.0 || ^11.0.0",
    "@opentelemetry/api": "^1.9.0",
    "msgpackr": "^1.11.0",
    "prom-client": "^15.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    },
    "msgpackr": {
      "optional": true
    },
    "prom-client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@golevelup/ts-vitest": "^4.0.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/microservices": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/testing": "^11.1.27",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^2.8.0",
    "@opentelemetry/core": "^2.8.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@types/node": "^25.9.4",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "hdr-histogram-js": "^3.0.1",
    "msgpackr": "^2.0.4",
    "prettier": "^3.9.4",
    "prom-client": "^15.1.3",
    "testcontainers": "^12.0.4",
    "tinybench": "^6.0.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.5",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@nats-io/jetstream": "^3.4.0",
    "@nats-io/kv": "^3.4.0",
    "@nats-io/nuid": "^3.0.0",
    "@nats-io/transport-node": "^3.4.0"
  }
}
